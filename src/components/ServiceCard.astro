---
import type { Service } from '../data/services';

interface Props {
  service: Service;
}

const { service } = Astro.props;

const iconMap: Record<string, string> = {
  artery: `<svg class="w-10 h-10" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><circle cx="24" cy="24" r="16" /><path d="M24 8v32M16 16c4 4 8 4 12 0M16 32c4-4 8-4 12 0" stroke-linecap="round"/></svg>`,
  aorta: `<svg class="w-10 h-10" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M24 6v8M24 34v8M20 14c-4 4-6 8-6 14s2 6 6 6h8c4 0 6 0 6-6s-2-10-6-14" stroke-linecap="round" stroke-linejoin="round"/><circle cx="24" cy="24" r="3"/></svg>`,
  heart: `<svg class="w-10 h-10" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M24 42s-16-8.4-16-20.25c0-4.97 3.73-9 8.33-9 3.07 0 5.72 1.67 7.67 4.33 1.95-2.66 4.6-4.33 7.67-4.33 4.6 0 8.33 4.03 8.33 9C40 33.6 24 42 24 42z" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 24h6l2-4 4 8 2-4h6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  leg: `<svg class="w-10 h-10" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M22 6c0 4-2 10-2 16s2 10 2 16M26 6c0 4 2 10 2 16s-2 10-2 16" stroke-linecap="round"/><path d="M18 18h12M18 30h12" stroke-linecap="round" opacity="0.5"/></svg>`,
};
---

<div class="bg-white rounded-card p-6 shadow-md hover:shadow-lg transition-all duration-300 group">
  <div class="text-gold mb-4" set:html={iconMap[service.icon] || iconMap.heart} />
  <h3 class="font-sans font-semibold text-lg text-charcoal mb-2 group-hover:text-navy transition-colors">{service.shortTitle}</h3>
  <p class="text-sm text-slate font-sans leading-relaxed line-clamp-3">{service.shortDescription}</p>
  <a href={`/services#${service.slug}`} class="inline-flex items-center gap-1 mt-4 text-sm font-sans font-medium text-navy hover:text-gold transition-colors">
    Learn More
    <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </a>
</div>
