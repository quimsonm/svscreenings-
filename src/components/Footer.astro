---
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';
---

<footer class="bg-navy-dark text-white">
  <div class="container-site py-16 md:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Column 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={link('/')} class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 8C16 8 10 14 10 22C10 30 16 40 24 44C32 40 38 30 38 22C38 14 32 8 24 8Z" stroke="#C8963E" stroke-width="2.5" fill="none"/>
              <path d="M16 24C18 20 20 18 24 18" stroke="#C8963E" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M14 24C17 17 20 14 24 14" stroke="#C8963E" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
              <path d="M18 24C20 22 22 21 24 21" stroke="#C8963E" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
              <circle cx="24" cy="24" r="2.5" fill="#C8963E"/>
            </svg>
          </div>
          <div>
            <span class="text-base font-sans font-semibold text-white tracking-wide">SIGNAL VIEW</span>
            <span class="block text-[10px] font-sans font-medium text-white/60 tracking-[0.12em] uppercase -mt-0.5">SCREENINGS</span>
          </div>
        </a>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Premium concierge ultrasound screenings in Las Vegas. Hospital-grade technology, expert sonographers, life-saving results.
        </p>
        <!-- Google Reviews Link -->
        <a href={siteConfig.googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-4 text-sm text-gold hover:text-gold-light transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          See Our Google Reviews
        </a>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h4 class="font-sans font-semibold text-sm uppercase tracking-wider text-white/90 mb-4">Quick Links</h4>
        <ul class="space-y-2.5">
          {[
            { label: 'Home', href: link('/') },
            { label: 'Services', href: link('/services') },
            { label: 'Pricing', href: link('/pricing') },
            { label: 'About Us', href: link('/about') },
            { label: 'FAQ', href: link('/faq') },
            { label: 'Contact', href: link('/contact') },
          ].map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/70 hover:text-gold transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h4 class="font-sans font-semibold text-sm uppercase tracking-wider text-white/90 mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{siteConfig.address.clinic}<br/>{siteConfig.address.full}</span>
          </li>
          <li>
            <a href={`tel:${siteConfig.phoneTel}`} class="flex items-center gap-2.5 hover:text-gold transition-colors">
              <svg class="w-4 h-4 shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {siteConfig.phone}
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{siteConfig.hours}</span>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-2.5 hover:text-gold transition-colors">
              <svg class="w-4 h-4 shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Service Area -->
      <div>
        <h4 class="font-sans font-semibold text-sm uppercase tracking-wider text-white/90 mb-4">Service Area</h4>
        <ul class="space-y-2.5 text-sm text-white/70">
          {siteConfig.serviceAreas.map((area) => (
            <li class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-gold" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {area}
            </li>
          ))}
        </ul>
        <div class="mt-5 p-3 bg-white/5 rounded-lg border border-white/10">
          <p class="text-xs text-white/60">
            <span class="text-gold font-semibold">Gold Standard</span> mobile service available throughout the Greater Las Vegas area.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/50">
      <p>&copy; {new Date().getFullYear()} {siteConfig.legalName}. All rights reserved.</p>
      <div class="flex gap-4">
        <a href={link('/privacy')} class="hover:text-white/80 transition-colors">Privacy Policy</a>
        <a href={link('/terms')} class="hover:text-white/80 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
