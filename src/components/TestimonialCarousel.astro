---
import { testimonials } from '../data/testimonials';
import { siteConfig } from '../data/siteConfig';
---

<section class="section-padding bg-ivory">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto mb-12 fade-in-up">
      <h2 class="text-3xl md:text-4xl font-serif text-charcoal">What Our Patients Say</h2>
      <p class="mt-3 text-lg text-slate font-sans">Real experiences from people who trusted us with their health</p>
    </div>

    <!-- Carousel -->
    <div class="relative">
      <div id="testimonial-track" class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-5 px-5 md:mx-0 md:px-0 no-scrollbar">
        {testimonials.map((t) => (
          <div class="snap-center shrink-0 w-[85%] sm:w-[45%] lg:w-[31%] bg-white rounded-card p-6 shadow-md">
            <!-- Stars -->
            <div class="flex gap-0.5 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-sm text-charcoal font-sans leading-relaxed mb-4">
              "{t.quote}"
            </blockquote>
            <p class="text-sm font-sans font-semibold text-navy">{t.name}</p>
          </div>
        ))}
      </div>

      <!-- Navigation dots -->
      <div class="flex justify-center gap-2 mt-6">
        {testimonials.map((_, i) => (
          <button
            class="testimonial-dot w-2.5 h-2.5 rounded-full bg-warmgray transition-colors"
            data-index={i}
            aria-label={`Go to testimonial ${i + 1}`}
          />
        ))}
      </div>
    </div>

    <!-- Google Reviews CTA -->
    <div class="text-center mt-8 fade-in-up">
      <a href={siteConfig.googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-sans font-medium text-navy hover:text-gold transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        See Our Reviews on Google
      </a>
    </div>
  </div>
</section>

<style>
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const track = document.getElementById('testimonial-track');
  const dots = document.querySelectorAll('.testimonial-dot');

  if (track && dots.length > 0) {
    dots[0]?.classList.add('!bg-gold');

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = Number(dot.getAttribute('data-index'));
        const cards = track.children;
        if (cards[index]) {
          (cards[index] as HTMLElement).scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });
    });

    track.addEventListener('scroll', () => {
      const scrollLeft = track.scrollLeft;
      const cardWidth = (track.children[0] as HTMLElement)?.offsetWidth || 300;
      const activeIndex = Math.round(scrollLeft / (cardWidth + 24));
      dots.forEach((dot, i) => {
        dot.classList.toggle('!bg-gold', i === activeIndex);
      });
    });
  }
</script>
