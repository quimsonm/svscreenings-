---
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

interface Props {
  heading?: string;
  subtext?: string;
  ctaText?: string;
  ctaHref?: string;
  showPhone?: boolean;
}

const {
  heading = "Take the First Step",
  subtext = 'Weekday and Saturday appointments available — reserve yours this week.',
  ctaText = 'Book Your Screening',
  ctaHref = link('/pricing'),
  showPhone = true,
} = Astro.props;
---

<section class="relative overflow-hidden bg-navy">
  <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/80 to-navy/80"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold/5 rounded-full blur-3xl"></div>

  <div class="container-site relative py-16 md:py-20 text-center">
    <h2 class="text-3xl md:text-4xl font-serif text-white mb-4 fade-in-up">{heading}</h2>
    <p class="text-lg text-white/70 font-sans mb-8 max-w-xl mx-auto fade-in-up">{subtext}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in-up">
      <a href={ctaHref} onclick={`window.svs_track && window.svs_track('cta_click', {link_text: '${ctaText}', link_location: 'cta_banner'})`} class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl">
        {ctaText}
      </a>
      {showPhone && (
        <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'cta_banner'})" class="inline-flex items-center gap-2 px-6 py-3.5 border-2 border-white/30 hover:border-white/60 text-white font-sans font-medium rounded-lg transition-all duration-200">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {siteConfig.phone}
        </a>
      )}
    </div>
  </div>
</section>
