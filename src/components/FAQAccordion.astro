---
import type { FAQItem } from '../data/faq';

interface Props {
  items: FAQItem[];
  grouped?: boolean;
}

const { items, grouped = false } = Astro.props;

// Group by category if requested
const categories = grouped
  ? [...new Set(items.map((item) => item.category))]
  : [null];

const groupedItems = grouped
  ? categories.map((cat) => ({
      category: cat,
      items: items.filter((item) => item.category === cat),
    }))
  : [{ category: null, items }];
---

<div class="space-y-8">
  {groupedItems.map((group) => (
    <div>
      {group.category && (
        <h3 class="font-sans font-semibold text-lg text-charcoal mb-4">{group.category}</h3>
      )}
      <div class="space-y-3">
        {group.items.map((item) => (
          <details class="group bg-white rounded-card border border-warmgray/60 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm md:text-base font-sans font-medium text-charcoal hover:text-navy transition-colors list-none">
              <span>{item.question}</span>
              <svg class="w-5 h-5 text-slate shrink-0 ml-4 transform transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-slate font-sans leading-relaxed border-t border-warmgray/30 pt-3">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  ))}
</div>
