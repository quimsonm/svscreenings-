---
import { siteConfig } from '../data/siteConfig';
---

<form id="contact-form" class="bg-white rounded-card shadow-lg p-6 md:p-8 space-y-5">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="contact-first" class="block text-sm font-sans font-medium text-charcoal mb-1.5">First Name *</label>
      <input type="text" id="contact-first" name="firstName" required
        class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="First name" />
    </div>
    <div>
      <label for="contact-last" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Last Name *</label>
      <input type="text" id="contact-last" name="lastName" required
        class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="Last name" />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="contact-phone" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Phone</label>
      <input type="tel" id="contact-phone" name="phone"
        class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="(702) 555-0123" />
    </div>
    <div>
      <label for="contact-email" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Email *</label>
      <input type="email" id="contact-email" name="email" required
        class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="you@example.com" />
    </div>
  </div>

  <div>
    <label for="contact-subject" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Subject</label>
    <select id="contact-subject" name="subject"
      class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
      <option value="general">General Question</option>
      <option value="booking">Booking Inquiry</option>
      <option value="insurance">Insurance / Payment Question</option>
      <option value="gold-standard">Gold Standard / Mobile Service</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Message *</label>
    <textarea id="contact-message" name="message" rows="5" required
      class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
      placeholder="How can we help you?"></textarea>
  </div>

  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <input type="text" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <button type="submit" class="w-full py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
    Send Message
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    const subject = encodeURIComponent(`Website Contact: ${data.subject}`);
    const body = encodeURIComponent(
      `Name: ${data.firstName} ${data.lastName}\nPhone: ${data.phone || 'Not provided'}\nEmail: ${data.email}\nSubject: ${data.subject}\n\nMessage:\n${data.message}`
    );
    (window as any).svs_track?.('generate_lead', { form_name: 'contact' });
    window.location.href = `mailto:signalviewultrasound@gmail.com?subject=${subject}&body=${body}`;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) {
      btn.textContent = 'Opening Email — Thank You!';
      btn.classList.remove('bg-gold', 'hover:bg-gold-hover');
      btn.classList.add('bg-green-600');
      btn.disabled = true;
    }
  });
</script>
