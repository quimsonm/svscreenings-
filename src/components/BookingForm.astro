---
import { packages } from '../data/packages';
import { siteConfig } from '../data/siteConfig';
---

<section id="booking" class="section-padding bg-ivory">
  <div class="container-site max-w-2xl">
    <div class="text-center mb-10 fade-in-up">
      <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Ready to Book?</h2>
      <p class="mt-3 text-lg text-slate font-sans">Request your appointment and we'll confirm within 24 hours.</p>
    </div>

    <form id="booking-form" class="bg-white rounded-card shadow-lg p-6 md:p-8 space-y-5 fade-in-up">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="booking-name" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Full Name *</label>
          <input type="text" id="booking-name" name="name" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            placeholder="Your full name" />
        </div>
        <div>
          <label for="booking-phone" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Phone Number *</label>
          <input type="tel" id="booking-phone" name="phone" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            placeholder="(702) 555-0123" />
        </div>
      </div>

      <div>
        <label for="booking-email" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Email Address *</label>
        <input type="email" id="booking-email" name="email" required
          class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
          placeholder="you@example.com" />
      </div>

      <div>
        <label for="booking-package" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Select Package *</label>
        <select id="booking-package" name="package" required
          class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
          <option value="">Choose a package...</option>
          {packages.map((pkg) => (
            <option value={pkg.name}>{pkg.name} — ${pkg.price}</option>
          ))}
        </select>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="booking-date" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Preferred Date *</label>
          <input type="date" id="booking-date" name="date" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors" />
        </div>
        <div>
          <label for="booking-time" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Preferred Time</label>
          <select id="booking-time" name="time"
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
            <option value="morning">Morning (9am – 11am)</option>
            <option value="midday">Midday (11am – 1pm)</option>
          </select>
        </div>
      </div>

      <div>
        <label for="booking-notes" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Special Notes</label>
        <textarea id="booking-notes" name="notes" rows="3"
          class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
          placeholder="Any questions or special requests..."></textarea>
      </div>

      <!-- Honeypot -->
      <div class="hidden" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <button type="submit" class="w-full py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
        Request Your Appointment
      </button>

      <p class="text-center text-xs text-slate font-sans">
        We'll confirm your appointment within 24 hours. Payment processed securely via Square.
      </p>
    </form>

    <p class="text-center mt-6 text-sm text-slate font-sans fade-in-up">
      Prefer to call?
      <a href={`tel:${siteConfig.phoneTel}`} class="text-navy font-medium hover:text-gold transition-colors">{siteConfig.phone}</a>
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    // Check honeypot
    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // For now, construct mailto link as fallback
    const subject = encodeURIComponent(`Booking Request: ${data.package}`);
    const body = encodeURIComponent(
      `Name: ${data.name}\nPhone: ${data.phone}\nEmail: ${data.email}\nPackage: ${data.package}\nPreferred Date: ${data.date}\nPreferred Time: ${data.time}\nNotes: ${data.notes || 'None'}`
    );
    window.location.href = `mailto:signalviewultrasound@gmail.com?subject=${subject}&body=${body}`;

    // Show success state
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) {
      btn.textContent = 'Opening Email — Thank You!';
      btn.classList.remove('bg-gold', 'hover:bg-gold-hover');
      btn.classList.add('bg-green-600');
      btn.disabled = true;
    }
  });
</script>
