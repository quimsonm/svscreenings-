---
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

const navLinks = [
  { label: 'Services', href: link('/services') },
  { label: 'Pricing', href: link('/pricing') },
  { label: 'About', href: link('/about') },
  { label: 'FAQ', href: link('/faq') },
  { label: 'Contact', href: link('/contact') },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-all duration-300">
  <div class="container-site">
    <div class="flex items-center justify-between h-20 transition-all duration-300" id="header-inner">
      <!-- Logo -->
      <a href={link('/')} class="flex items-center gap-3 shrink-0">
        <div class="w-10 h-10 bg-navy rounded-xl flex items-center justify-center">
          <svg width="24" height="24" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 8C16 8 10 14 10 22C10 30 16 40 24 44C32 40 38 30 38 22C38 14 32 8 24 8Z" stroke="#C8963E" stroke-width="2.5" fill="none"/>
            <path d="M16 24C18 20 20 18 24 18" stroke="#C8963E" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M14 24C17 17 20 14 24 14" stroke="#C8963E" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
            <path d="M18 24C20 22 22 21 24 21" stroke="#C8963E" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
            <circle cx="24" cy="24" r="2.5" fill="#C8963E"/>
          </svg>
        </div>
        <div>
          <span class="text-sm sm:text-base font-sans font-semibold text-charcoal tracking-wide">SIGNAL VIEW</span>
          <span class="block text-[9px] sm:text-[10px] font-sans font-medium text-slate tracking-[0.12em] uppercase -mt-0.5">SCREENINGS</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm font-sans font-medium text-slate hover:text-navy transition-colors">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: Phone + CTA + Mobile Menu -->
      <div class="flex items-center gap-4">
        <a href={`tel:${siteConfig.phoneTel}`} class="hidden md:flex items-center gap-2 text-sm font-sans font-medium text-slate hover:text-navy transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {siteConfig.phone}
        </a>

        <a href={link('/pricing#booking')} class="inline-flex items-center px-3 py-2 sm:px-5 sm:py-2.5 bg-gold hover:bg-gold-hover text-white text-xs sm:text-sm font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
          <span class="sm:hidden">Book Now</span>
          <span class="hidden sm:inline">Book Your Screening</span>
        </a>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden flex items-center justify-center w-10 h-10 text-charcoal" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" id="menu-open-icon" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-20 bg-white z-[999] transform translate-x-full pointer-events-none transition-transform duration-300 ease-in-out overflow-y-auto">
    <nav class="flex flex-col p-6 gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="text-lg font-sans font-medium text-charcoal hover:text-navy py-3 border-b border-warmgray/50 transition-colors">
          {link.label}
        </a>
      ))}
      <div class="mt-6 flex flex-col gap-3">
        <a href={`tel:${siteConfig.phoneTel}`} class="flex items-center justify-center gap-2 py-3 text-base font-sans font-medium text-navy border-2 border-navy rounded-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {siteConfig.phone}
        </a>
        <a href={link('/pricing#booking')} class="flex items-center justify-center py-3 bg-gold hover:bg-gold-hover text-white text-base font-sans font-semibold rounded-lg transition-colors">
          Book Your Screening
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let isOpen = false;

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full', 'pointer-events-none');
    mobileMenu?.classList.add('translate-x-0', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    isOpen = true;
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full', 'pointer-events-none');
    mobileMenu?.classList.remove('translate-x-0', 'pointer-events-auto');
    document.body.style.overflow = '';
    isOpen = false;
  }

  menuBtn?.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  // Header shrink on scroll
  const header = document.getElementById('site-header');
  const headerInner = document.getElementById('header-inner');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('shadow-md');
      headerInner?.classList.add('!h-16');
    } else {
      header?.classList.remove('shadow-md');
      headerInner?.classList.remove('!h-16');
    }
  });
</script>
