---
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';
import logo from '../assets/images/logo.png';

const navLinks = [
  { label: 'Services', href: link('/services') },
  { label: 'Pricing', href: link('/pricing') },
  { label: 'Diagnostics', href: link('/diagnostics') },
  { label: 'About', href: link('/about') },
  { label: 'FAQ', href: link('/faq') },
  { label: 'Gift Cards', href: link('/gift') },
  { label: 'Contact', href: link('/contact') },
  { label: 'Health Articles', href: link('/blog') },
  { label: 'For Physicians', href: link('/partners') },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-all duration-300">
  <div class="container-site">
    <!-- Desktop: single row -->
    <div class="hidden lg:flex items-center justify-between h-20 transition-all duration-300" id="header-inner">
      <a href={link('/')} class="flex items-center gap-3 shrink-0">
        <img src={logo.src} alt="Signal View Screenings" class="w-10 h-10 rounded-full" />
        <div>
          <span class="text-base font-sans font-semibold text-charcoal tracking-wide">SIGNAL VIEW</span>
          <span class="block text-[10px] font-sans font-medium text-slate tracking-[0.12em] uppercase -mt-0.5">SCREENINGS</span>
        </div>
      </a>
      <nav class="flex items-center gap-8">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm font-sans font-medium text-slate hover:text-navy transition-colors">
            {link.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-3">
        <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'header'})" class="inline-flex items-center px-3 py-2 text-xs font-sans font-medium text-navy border border-navy/30 hover:border-navy rounded-md transition-colors">
          Call Us
        </a>
        <a href={`sms:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_text', {link_location: 'header'})" class="inline-flex items-center px-3 py-2 text-xs font-sans font-medium text-navy border border-navy/30 hover:border-navy rounded-md transition-colors">
          Text Us
        </a>
        <a href={link('/pricing')} onclick="window.svs_track && window.svs_track('cta_click', {link_text: 'Book Online', link_location: 'header'})" class="inline-flex items-center px-4 py-2 bg-gold hover:bg-gold-hover text-white text-xs font-sans font-semibold rounded-md transition-all duration-200 shadow-sm hover:shadow-md">
          Book Online
        </a>
      </div>
    </div>

    <!-- Mobile: logo row + buttons row -->
    <div class="lg:hidden">
      <div class="flex items-center justify-between h-14">
        <a href={link('/')} class="flex items-center gap-2 shrink-0">
          <img src={logo.src} alt="Signal View Screenings" class="w-8 h-8 rounded-full" />
          <div>
            <span class="text-sm font-sans font-semibold text-charcoal tracking-wide">SIGNAL VIEW</span>
            <span class="block text-[9px] font-sans font-medium text-slate tracking-[0.12em] uppercase -mt-0.5">SCREENINGS</span>
          </div>
        </a>
        <button id="mobile-menu-btn" class="relative z-[60] flex items-center justify-center w-10 h-10 -mr-1 text-charcoal" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <div class="flex items-center gap-2 pb-2">
        <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'header'})" class="flex-1 inline-flex items-center justify-center py-2 text-xs font-sans font-medium text-navy border border-navy/30 hover:border-navy rounded-md transition-colors">
          Call Us
        </a>
        <a href={`sms:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_text', {link_location: 'header'})" class="flex-1 inline-flex items-center justify-center py-2 text-xs font-sans font-medium text-navy border border-navy/30 hover:border-navy rounded-md transition-colors">
          Text Us
        </a>
        <a href={link('/pricing')} onclick="window.svs_track && window.svs_track('cta_click', {link_text: 'Book Online', link_location: 'header'})" class="flex-1 inline-flex items-center justify-center py-2 bg-gold hover:bg-gold-hover text-white text-xs font-sans font-semibold rounded-md transition-all duration-200 shadow-sm hover:shadow-md">
          Book Online
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu - OUTSIDE header to avoid stacking context issues -->
<div id="mobile-menu" class="lg:hidden fixed inset-0 top-[88px] z-[9999] hidden" aria-hidden="true">
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/20"></div>
  <!-- Menu panel -->
  <div class="relative bg-white h-full overflow-y-auto shadow-xl">
    <nav class="flex flex-col p-6 gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="text-lg font-sans font-medium text-charcoal hover:text-navy py-3 border-b border-warmgray/50 transition-colors">
          {link.label}
        </a>
      ))}
      <div class="mt-6 flex flex-col gap-3">
        <div class="grid grid-cols-2 gap-3">
          <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'mobile_menu'})" class="flex items-center justify-center gap-2 py-3 text-base font-sans font-medium text-navy border-2 border-navy rounded-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Us
          </a>
          <a href={`sms:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_text', {link_location: 'mobile_menu'})" class="flex items-center justify-center gap-2 py-3 text-base font-sans font-medium text-navy border-2 border-navy rounded-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Text Us
          </a>
        </div>
        <a href={link('/pricing')} onclick="window.svs_track && window.svs_track('cta_click', {link_text: 'Book Online', link_location: 'mobile_menu'})" class="flex items-center justify-center py-3 bg-gold hover:bg-gold-hover text-white text-base font-sans font-semibold rounded-lg transition-colors">
          Book Online
        </a>
      </div>
    </nav>
  </div>
</div>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var menuBtn = document.getElementById('mobile-menu-btn');
    var mobileMenu = document.getElementById('mobile-menu');
    var backdrop = document.getElementById('mobile-menu-backdrop');
    var isOpen = false;

    function openMenu() {
      mobileMenu.classList.remove('hidden');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      isOpen = true;
    }

    function closeMenu() {
      mobileMenu.classList.add('hidden');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      isOpen = false;
    }

    if (menuBtn) {
      menuBtn.addEventListener('click', function() {
        if (isOpen) { closeMenu(); } else { openMenu(); }
      });
    }

    if (backdrop) {
      backdrop.addEventListener('click', function() { closeMenu(); });
    }

    if (mobileMenu) {
      var links = mobileMenu.querySelectorAll('a');
      for (var i = 0; i < links.length; i++) {
        links[i].addEventListener('click', function() { closeMenu(); });
      }
    }

    // Header shrink on scroll
    var header = document.getElementById('site-header');
    var headerInner = document.getElementById('header-inner');
    window.addEventListener('scroll', function() {
      if (window.scrollY > 80) {
        header.classList.add('shadow-md');
        headerInner.classList.add('!h-16');
      } else {
        header.classList.remove('shadow-md');
        headerInner.classList.remove('!h-16');
      }
    });
  });
</script>
