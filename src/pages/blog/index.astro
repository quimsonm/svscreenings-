---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABanner from '../../components/CTABanner.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
import { link } from '../../utils/links';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog | Health Screening Insights | Signal View Screenings Las Vegas"
  description="Expert insights on preventative health screenings, vascular health, and early detection from the sonographers at Signal View Screening Services in Las Vegas."
>
  <PageHero
    title="Learn More"
    subtitle="Expert articles on preventative screening, vascular health, and early detection"
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'Learn More' }]}
  />

  <section class="section-padding bg-white">
    <div class="container-site max-w-4xl">
      {posts.length === 0 ? (
        <p class="text-center text-slate font-sans">No posts yet. Check back soon.</p>
      ) : (
        <div class="space-y-8 fade-in-up">
          {posts.map((post) => (
            <a href={link(`/blog/${post.slug}`)} class="block bg-ivory rounded-card p-6 md:p-8 border border-warmgray/40 hover:border-gold/40 hover:shadow-lg transition-all duration-300 group">
              <div class="flex items-center gap-3 mb-3">
                <time datetime={post.data.pubDate.toISOString()} class="text-xs font-sans text-slate">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.author && (
                  <>
                    <span class="text-warmgray">|</span>
                    <span class="text-xs font-sans text-slate">{post.data.author}</span>
                  </>
                )}
              </div>
              <h2 class="text-xl md:text-2xl font-serif text-charcoal group-hover:text-navy transition-colors mb-3">
                {post.data.title}
              </h2>
              <p class="text-sm text-slate font-sans leading-relaxed mb-4">
                {post.data.description}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-sans font-medium text-navy group-hover:text-gold transition-colors">
                Read More
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <NewsletterSignup />

  <CTABanner
    heading="Ready to Get Screened?"
    subtext="Don't wait for symptoms. Book your screening today."
  />
</BaseLayout>
