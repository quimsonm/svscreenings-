---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PricingCard from '../components/PricingCard.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CTABanner from '../components/CTABanner.astro';
import { packages } from '../data/packages';
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

import serviceResults from '../assets/images/service-results.png';
import conciergeHome from '../assets/images/concierge-home.png';
---

<BaseLayout
  title="Signal View Screenings | Premium Ultrasound Screenings in Las Vegas"
  description="Hospital-grade ultrasound screenings in Las Vegas. Detect heart disease, stroke risk, and vascular conditions early. No referral needed. Packages from $199. Book your appointment today."
>
  <!-- Schema.org structured data -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    "name": siteConfig.legalName,
    "description": "Premium concierge ultrasound screening services in Las Vegas. Hospital-grade technology for early detection of heart disease, stroke risk, and vascular conditions.",
    "url": siteConfig.domain,
    "telephone": siteConfig.phoneTel,
    "email": siteConfig.email,
    "areaServed": {
      "@type": "City",
      "name": "Las Vegas",
      "containedInPlace": { "@type": "State", "name": "Nevada" }
    },
    "priceRange": "$199 - $597",
    "medicalSpecialty": "Diagnostic Radiology"
  })} />

  <!-- ===== HERO ===== -->
  <section class="relative bg-navy overflow-hidden min-h-[60vh] md:min-h-[55vh] flex items-center">
    <!-- Video Background -->
    <video
      autoplay
      muted
      playsinline
      preload="auto"
      class="absolute inset-0 w-full h-full object-cover"
      poster={conciergeHome.src}
    >
      <source src={link('/hero-video.mp4')} type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/70 via-navy/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-ivory to-transparent"></div>

    <div class="container-site relative py-16 md:py-20">
      <div class="max-w-3xl">
        <p class="overline text-gold mb-5">
          Preventative Ultrasound Screenings in Las Vegas
        </p>

        <h1 class="text-display-sm md:text-display font-serif text-white leading-tight">
          Hospital-Grade Screenings.<br class="hidden sm:block" />
          <span class="text-gold-light">White-Glove Experience.</span>
        </h1>

        <p class="mt-6 text-lg md:text-xl text-white/90 font-sans leading-relaxed max-w-2xl">
          Non-invasive ultrasound screenings that detect heart disease, stroke risk, and vascular conditions early — when treatment is most effective. No referrals needed.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={link('/pricing')} onclick="window.svs_track && window.svs_track('cta_click', {link_text: 'Book Your Screening', link_location: 'hero'})" class="inline-flex items-center justify-center px-8 py-4 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl text-base">
            Book Your Screening
          </a>
          <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'hero'})" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/40 hover:border-white/80 text-white font-sans font-medium rounded-lg transition-all duration-200 text-base">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {siteConfig.phone}
          </a>
        </div>

        <p class="mt-5 text-base text-gold-light font-sans font-medium">
          Packages from $199 · HSA/FSA Eligible · No Referral Needed
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/70 font-sans">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            10+ Years Experience
          </span>
          <span class="hidden sm:inline text-white/30">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            5-Star Rated
          </span>
          <span class="hidden sm:inline text-white/30">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
            Summerlin, Las Vegas
          </span>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- ===== SOCIAL PROOF QUOTE + LOCATION/HOURS STRIP ===== -->
  <section class="bg-ivory border-b border-warmgray/40">
    <div class="container-site py-8 md:py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-center">
        <!-- Single testimonial -->
        <div class="md:col-span-2 fade-in-up">
          <div class="flex gap-0.5 mb-2">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-base md:text-lg text-charcoal font-sans leading-relaxed italic">
            "Quick service, very efficient, staff was welcoming, professional, and kind. Made our medical visit painless and reassuring."
          </blockquote>
          <p class="mt-2 text-sm font-sans font-semibold text-navy">— Caleb T., Google Review</p>
        </div>
        <!-- Hours / Location -->
        <div class="border-t md:border-t-0 md:border-l border-warmgray/60 pt-6 md:pt-0 md:pl-8 fade-in-up">
          <p class="overline text-gold mb-2">Appointments</p>
          <p class="text-sm font-sans font-semibold text-charcoal">Wednesday, Friday & Saturday</p>
          <p class="text-sm text-slate font-sans mt-1">{siteConfig.hours}</p>
          <p class="text-sm text-slate font-sans mt-3">
            Private medical office in Summerlin — address provided upon booking confirmation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY SCREENING MATTERS (moved up — frames value before pricing) ===== -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">Why It Matters</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Early Detection Saves Lives</h2>
          <p class="mt-4 text-lg text-slate font-sans leading-relaxed">
            Most cardiovascular conditions develop silently over years. By the time symptoms appear, the damage is often done. A simple screening can change everything.
          </p>

          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
              <p class="text-3xl font-serif text-navy">80%</p>
              <p class="text-sm text-slate font-sans mt-1">of strokes are preventable with early detection</p>
            </div>
            <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
              <p class="text-3xl font-serif text-navy">90%</p>
              <p class="text-sm text-slate font-sans mt-1">of aortic aneurysm ruptures are fatal — screening catches them early</p>
            </div>
          </div>

          <ul class="mt-8 space-y-3">
            {[
              'No doctor referral required',
              'Results explained in plain language',
              '30–60 minute appointments',
              'HSA/FSA eligible',
            ].map((item) => (
              <li class="flex items-center gap-3 text-sm font-sans text-charcoal">
                <svg class="w-5 h-5 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <div class="mt-8">
            <a href={link('/pricing')} onclick="window.svs_track && window.svs_track('cta_click', {link_text: 'Take Control of Your Health', link_location: 'why_it_matters'})" class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
              Take Control of Your Health
            </a>
          </div>
        </div>

        <div class="fade-in-up space-y-6">
          <img
            src={serviceResults.src}
            alt="Sonographer reviewing ultrasound results with patient"
            class="rounded-2xl w-full aspect-[4/3] object-cover shadow-lg"
            loading="lazy"
          />
          <div class="bg-navy rounded-2xl p-6 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-48 h-48 bg-gold/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative">
              <p class="overline text-gold mb-4">The cost of waiting</p>
              <div class="space-y-4">
                <div class="flex items-baseline justify-between">
                  <p class="text-sm text-white/60 font-sans">ER visit for stroke</p>
                  <p class="text-lg font-serif text-white">$20,000+</p>
                </div>
                <div class="border-t border-white/10 pt-4 flex items-baseline justify-between">
                  <p class="text-sm text-white/60 font-sans">Heart surgery</p>
                  <p class="text-lg font-serif text-white">$100,000+</p>
                </div>
                <div class="border-t border-white/10 pt-4 flex items-baseline justify-between">
                  <p class="text-sm text-gold font-sans font-semibold">Signal View screening</p>
                  <p class="text-lg font-serif text-gold">From $199</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRICING (moved up) ===== -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <p class="overline text-gold mb-3">Transparent Pricing</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Choose Your Screening Package</h2>
        <p class="mt-3 text-lg text-slate font-sans">No hidden fees. No referrals needed.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto fade-in-up">
        {packages.map((pkg) => (
          <PricingCard pkg={pkg} />
        ))}
      </div>

      <p class="text-center mt-8 text-sm text-slate font-sans fade-in-up">
        All screenings performed by highly trained sonographers with 5+ years experience.
        <a href={link('/pricing')} class="text-navy font-medium hover:text-gold transition-colors ml-1">View full pricing details →</a>
      </p>
    </div>
  </section>

  <TestimonialCarousel />
  <HowItWorks />
  <CTABanner />

</BaseLayout>
