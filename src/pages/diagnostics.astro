---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

import serviceResults from '../assets/images/service-results.png';

const diagnosticServices = [
  {
    name: 'Echocardiogram',
    price: 300,
    description: 'Comprehensive cardiac ultrasound evaluating heart muscle function, valve integrity, and blood flow.',
    icon: 'heart',
  },
  {
    name: 'Carotid Ultrasound',
    price: 250,
    description: 'Full diagnostic study of the carotid arteries to evaluate plaque buildup, stenosis, and stroke risk.',
    icon: 'artery',
  },
  {
    name: 'Aorta Ultrasound',
    price: 250,
    description: 'Diagnostic imaging of the abdominal aorta to evaluate for aneurysm, dilation, or other abnormalities.',
    icon: 'aorta',
  },
  {
    name: 'Lower Extremity Arterial',
    price: 250,
    description: 'Complete arterial study of the legs to assess blood flow, blockages, and peripheral artery disease.',
    icon: 'leg',
  },
  {
    name: 'Lower Extremity Venous',
    price: 250,
    description: 'Full venous study of the legs to evaluate for deep vein thrombosis (DVT), reflux, and venous insufficiency.',
    icon: 'leg',
  },
  {
    name: 'Abdominal Complete',
    price: 250,
    description: 'Comprehensive abdominal ultrasound covering the liver, gallbladder, pancreas, spleen, and kidneys.',
    icon: 'general',
  },
  {
    name: 'Thyroid Ultrasound',
    price: 250,
    description: 'Detailed imaging of the thyroid gland to evaluate nodules, cysts, and gland structure.',
    icon: 'general',
  },
  {
    name: 'Renal Ultrasound',
    price: 250,
    description: 'Diagnostic study of the kidneys and bladder to evaluate size, structure, stones, and blood flow.',
    icon: 'general',
  },
];

const iconMap: Record<string, string> = {
  heart: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
  artery: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8" /><path d="M12 4v16M8 8c2 2 4 2 6 0M8 16c2-2 4-2 6 0" stroke-linecap="round"/></svg>`,
  aorta: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 3v4M12 17v4M10 7c-2 2-3 4-3 7s1 3 3 3h4c2 0 3 0 3-3s-1-5-3-7" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="1.5"/></svg>`,
  leg: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M11 3c0 2-1 5-1 8s1 5 1 8M13 3c0 2 1 5 1 8s-1 5-1 8" stroke-linecap="round"/><path d="M9 9h6M9 15h6" stroke-linecap="round" opacity="0.5"/></svg>`,
  general: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
};
---

<BaseLayout
  title="Cash-Pay Diagnostic Ultrasound | No Insurance Needed | Signal View Las Vegas"
  description="Affordable cash-pay diagnostic ultrasound in Las Vegas. Echo $300, vascular and general studies from $250. All include physician interpretation. No insurance or referral required."
>
  <PageHero
    title="Cash-Pay Diagnostic Ultrasound"
    subtitle="Hospital-grade diagnostic studies at a fraction of the cost — no insurance needed"
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'Diagnostics' }]}
  />

  <!-- Value Proposition -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">Why Cash Pay?</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">The Same Diagnostic Ultrasound — Without the Insurance Hassle</h2>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            Need a diagnostic ultrasound? Skip the insurance runaround, high deductibles, and weeks-long wait times. Our cash-pay studies are the same hospital-grade diagnostic exams — performed by highly trained sonographers and interpreted by board-certified physicians — at a transparent, affordable price.
          </p>
          <div class="mt-6 space-y-3">
            {['All studies interpreted by a board-certified physician', 'Self-referred or with a doctor\'s order', 'No insurance authorization needed', 'Results you can share with your doctor', 'Wednesday, Friday & Saturday appointments'].map((item) => (
              <div class="flex items-center gap-2.5 text-sm font-sans text-charcoal">
                <svg class="w-4 h-4 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="fade-in-up">
          <img
            src={serviceResults.src}
            alt="Sonographer performing diagnostic ultrasound in a premium clinical setting"
            class="rounded-2xl w-full aspect-[4/3] object-cover shadow-lg"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Grid -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <p class="overline text-gold mb-3">Transparent Pricing</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Diagnostic Studies & Pricing</h2>
        <p class="mt-3 text-lg text-slate font-sans">All prices include physician interpretation. No hidden fees.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto fade-in-up">
        {diagnosticServices.map((service) => (
          <div class="bg-white rounded-card p-5 shadow-md border border-warmgray/30 hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 bg-gold/10 rounded-full flex items-center justify-center mb-3 text-gold" set:html={iconMap[service.icon]} />
            <h3 class="font-sans font-semibold text-charcoal text-sm mb-1">{service.name}</h3>
            <p class="text-2xl font-serif text-navy mb-2">${service.price}</p>
            <p class="text-xs text-slate font-sans leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8 fade-in-up">
        <p class="text-sm text-slate font-sans">
          <span class="font-medium text-charcoal">HSA/FSA eligible.</span> Patients may submit receipts to their insurance for potential reimbursement.
        </p>
      </div>
    </div>
  </section>

  <!-- Cost Comparison -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <div class="text-center mb-10 fade-in-up">
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Cash Pay vs. Insurance</h2>
        <p class="mt-3 text-lg text-slate font-sans">See what you save</p>
      </div>

      <div class="space-y-4 fade-in-up">
        <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-slate font-sans">Echo through insurance (with deductible)</span>
            <span class="text-lg font-serif text-charcoal">$1,500 – $2,500</span>
          </div>
        </div>
        <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-slate font-sans">Vascular study through insurance</span>
            <span class="text-lg font-serif text-charcoal">$800 – $1,500</span>
          </div>
        </div>
        <div class="bg-white rounded-card p-5 border-2 border-gold shadow-md">
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-gold-hover font-sans font-semibold">Signal View cash-pay diagnostic</span>
            <span class="text-lg font-serif text-gold">$250 – $300</span>
          </div>
        </div>
        <p class="text-center text-sm text-slate font-sans italic">
          Same diagnostic quality. Same physician interpretation. A fraction of the cost.
        </p>
      </div>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section id="diagnostic-inquiry" class="section-padding bg-navy">
    <div class="container-site max-w-2xl">
      <div class="text-center mb-10 fade-in-up">
        <p class="overline text-gold mb-3">Schedule Your Study</p>
        <h2 class="text-3xl md:text-4xl font-serif text-white">Request a Diagnostic Appointment</h2>
        <p class="mt-3 text-lg text-white/70 font-sans">Tell us what study you need and we'll get you scheduled. No referral required.</p>
      </div>

      <form id="diagnostic-form" class="bg-white rounded-card shadow-lg p-6 md:p-8 space-y-5 fade-in-up">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="dx-name" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Full Name *</label>
            <input type="text" id="dx-name" name="name" required
              class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              placeholder="Your full name" />
          </div>
          <div>
            <label for="dx-phone" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Phone Number *</label>
            <input type="tel" id="dx-phone" name="phone" required
              class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              placeholder="(702) 555-0123" />
          </div>
        </div>

        <div>
          <label for="dx-email" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Email Address *</label>
          <input type="email" id="dx-email" name="email" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            placeholder="you@example.com" />
        </div>

        <div>
          <label for="dx-study" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Study Needed *</label>
          <select id="dx-study" name="study" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
            <option value="">Select a study...</option>
            <option value="Echocardiogram ($300)">Echocardiogram — $300</option>
            <option value="Carotid Ultrasound ($250)">Carotid Ultrasound — $250</option>
            <option value="Aorta Ultrasound ($250)">Aorta Ultrasound — $250</option>
            <option value="Lower Extremity Arterial ($250)">Lower Extremity Arterial — $250</option>
            <option value="Lower Extremity Venous ($250)">Lower Extremity Venous — $250</option>
            <option value="Abdominal Complete ($250)">Abdominal Complete — $250</option>
            <option value="Thyroid Ultrasound ($250)">Thyroid Ultrasound — $250</option>
            <option value="Renal Ultrasound ($250)">Renal Ultrasound — $250</option>
            <option value="Multiple studies">Multiple studies — describe below</option>
          </select>
        </div>

        <div>
          <label for="dx-referral" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Do you have a doctor's order?</label>
          <select id="dx-referral" name="referral"
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
            <option value="self-referred">No — I'm self-referring</option>
            <option value="doctor-order">Yes — I have a doctor's order</option>
          </select>
        </div>

        <div>
          <label for="dx-notes" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Additional Notes</label>
          <textarea id="dx-notes" name="notes" rows="3"
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
            placeholder="Preferred dates, referring physician name, or any questions..."></textarea>
        </div>

        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="w-full py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
          Request Your Appointment
        </button>

        <p class="text-center text-xs text-slate font-sans">
          We'll confirm your appointment within 24 hours. Payment collected at time of service.
        </p>
      </form>

      <p class="text-center mt-6 text-sm text-white/60 font-sans fade-in-up">
        Prefer to call?
        <a href={`tel:${siteConfig.phoneTel}`} class="text-gold font-medium hover:text-gold-light transition-colors">{siteConfig.phone}</a>
      </p>
    </div>
  </section>

  <CTABanner
    heading="Looking for Preventative Screenings Instead?"
    subtext="Our screening packages start at $199 — no referral needed."
    ctaText="View Screening Packages"
    ctaHref={link('/pricing')}
  />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('diagnostic-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var honeypot = form.querySelector('input[name="website"]');
      if (honeypot && honeypot.value) return;

      var data = new FormData(form);
      var entries = {};
      data.forEach(function(value, key) { entries[key] = value; });

      var subject = encodeURIComponent('Diagnostic Ultrasound Request: ' + entries.study);
      var body = encodeURIComponent(
        'Name: ' + entries.name +
        '\nPhone: ' + entries.phone +
        '\nEmail: ' + entries.email +
        '\nStudy: ' + entries.study +
        '\nDoctor Order: ' + entries.referral +
        '\nNotes: ' + (entries.notes || 'None')
      );
      window.svs_track && window.svs_track('generate_lead', { form_name: 'diagnostic' });
      window.location.href = 'mailto:info@svscreenings.com?subject=' + subject + '&body=' + body;

      var btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.textContent = 'Opening Email — Thank You!';
        btn.classList.remove('bg-gold', 'hover:bg-gold-hover');
        btn.classList.add('bg-green-600');
        btn.disabled = true;
      }
    });
  });
</script>
