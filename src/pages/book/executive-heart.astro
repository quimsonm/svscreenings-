---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { siteConfig } from '../../data/siteConfig';
import { link } from '../../utils/links';
---

<BaseLayout
  title="Book Executive Heart Screening | $349 | Signal View Screenings"
  description="Book your Executive Heart ultrasound screening package. Carotid, aorta, leg arterial, and echocardiogram for $349. Select your time and pay online."
>
  <PageHero
    title="Book Your Executive Heart Screening"
    subtitle="Our most popular package. Select an available time, enter your details, and pay securely."
    breadcrumbs={[
      { label: 'Home', href: link('/') },
      { label: 'Pricing', href: link('/pricing') },
      { label: 'Book Executive Heart' },
    ]}
  />

  <section class="section-padding bg-ivory">
    <div class="container-site max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12">

        <!-- Left: Package Summary -->
        <div class="lg:col-span-2 fade-in-up">
          <div class="bg-white rounded-card p-6 shadow-md border border-warmgray/30 ring-2 ring-gold sticky top-24">
            <div class="flex items-center justify-between mb-2">
              <p class="overline text-gold">Executive Heart</p>
              <span class="text-xs font-sans font-semibold text-gold bg-gold/10 px-2.5 py-1 rounded-full">Most Popular</span>
            </div>
            <p class="text-4xl font-serif text-charcoal">$349</p>
            <p class="text-sm text-slate font-sans mt-1">~45 minutes · At our clinic</p>

            <hr class="my-5 border-warmgray/40" />

            <p class="text-sm font-sans font-semibold text-charcoal mb-3">What's included:</p>
            <ul class="space-y-2.5">
              {[
                'Carotid Artery Ultrasound',
                'Aorta Aneurysm Screening',
                'Leg Arterial Ultrasound',
                'Echocardiogram (Heart Ultrasound)',
                'Same-day screening summary',
              ].map((item) => (
                <li class="flex items-center gap-2.5 text-sm font-sans text-charcoal">
                  <svg class="w-4 h-4 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>

            <div class="mt-4 bg-gold/5 border border-gold/20 rounded-lg p-3">
              <p class="text-xs font-sans text-charcoal">
                <strong>Optional:</strong> Add board-certified physician interpretation for +$49
              </p>
            </div>

            <hr class="my-5 border-warmgray/40" />

            <div class="space-y-2">
              <div class="flex items-center gap-2 text-sm text-slate font-sans">
                <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                3150 N Tenaya Wy, Suite 400
              </div>
              <div class="flex items-center gap-2 text-sm text-slate font-sans">
                <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Wed 12-5pm · Fri 12-5pm · Sat 9am-1pm
              </div>
            </div>

            <hr class="my-5 border-warmgray/40" />

            <p class="text-xs text-slate font-sans leading-relaxed">
              Screenings are elective and cash-pay. HSA/FSA eligible. Payment processed securely through Square.
            </p>

            <div class="mt-5 pt-4 border-t border-warmgray/40">
              <p class="text-sm font-sans text-charcoal font-medium mb-1">Prefer to call or text?</p>
              <div class="flex gap-3">
                <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'book_executive'})" class="text-sm font-sans text-navy hover:text-gold transition-colors">
                  Call {siteConfig.phone}
                </a>
                <span class="text-warmgray">|</span>
                <a href={`sms:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_text', {link_location: 'book_executive'})" class="text-sm font-sans text-navy hover:text-gold transition-colors">
                  Text us
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Square Booking Widget -->
        <div class="lg:col-span-3 fade-in-up">
          <div class="bg-white rounded-card shadow-md border border-warmgray/30 p-4 md:p-6">
            <h2 class="text-xl font-serif text-charcoal mb-4">Select Your Appointment</h2>
            <div class="sq-widget-container">
              <script is:inline src='https://square.site/appointments/buyer/widget/1scmcc76vpn2fe/L0GR90314NDDP.js'></script>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sq-widget-container :global(iframe) {
    width: 100% !important;
    min-height: 700px;
    border: none !important;
    border-radius: 8px;
  }
</style>
