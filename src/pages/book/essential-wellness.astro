---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/siteConfig';
import { link } from '../../utils/links';
---

<BaseLayout
  title="Book Essential Wellness Screening | $199 | Signal View Screenings"
  description="Book your Essential Wellness ultrasound screening package. Carotid, aorta, and leg arterial screenings for $199. Select your time and pay online."
>
  <section class="bg-navy relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-dark/50 to-transparent"></div>
    <div class="container-site relative py-10 md:py-14">
      <nav class="mb-3 flex items-center gap-2 text-sm text-white/50" aria-label="Breadcrumb">
        <a href={link('/')} class="hover:text-white/80 transition-colors">Home</a>
        <span class="text-white/30">/</span>
        <a href={link('/pricing')} class="hover:text-white/80 transition-colors">Pricing</a>
        <span class="text-white/30">/</span>
        <span class="text-white/70">Book Essential Wellness</span>
      </nav>
      <h1 class="text-2xl md:text-3xl font-serif text-white">Book Your Essential Wellness Screening</h1>
      <p class="mt-2 text-base text-white/70 font-sans">Choose your time, enter your details, and pay securely — all right here.</p>
    </div>
  </section>

  <section class="bg-ivory py-8 md:py-12">
    <div class="container-site max-w-2xl">
      <div class="bg-white rounded-card shadow-md border border-warmgray/30 p-4 md:p-6">
        <div class="sq-widget-container">
          <script is:inline src='https://square.site/appointments/buyer/widget/1scmcc76vpn2fe/L0GR90314NDDP.js'></script>
        </div>
      </div>

      <div class="mt-6 text-center">
        <p class="text-sm font-sans text-slate mb-2">Prefer to call or text?</p>
        <div class="flex items-center justify-center gap-4">
          <a href={`tel:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_phone', {link_location: 'book_essential'})" class="text-sm font-sans font-medium text-navy hover:text-gold transition-colors">
            Call {siteConfig.phone}
          </a>
          <span class="text-warmgray">|</span>
          <a href={`sms:${siteConfig.phoneTel}`} onclick="window.svs_track && window.svs_track('click_text', {link_location: 'book_essential'})" class="text-sm font-sans font-medium text-navy hover:text-gold transition-colors">
            Text us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sq-widget-container :global(iframe) {
    width: 100% !important;
    min-height: 700px;
    border: none !important;
    border-radius: 8px;
  }
</style>
