---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

import serviceCarotid from '../assets/images/service-carotid.png';
---

<BaseLayout
  title="Partner With Us | Diagnostic Ultrasound Services for Physicians & Clinics | Signal View"
  description="Partner with Signal View for full diagnostic ultrasound technologist services. 10+ years serving Las Vegas clinics. Reliable, credentialed sonographers for your practice."
>
  <PageHero
    title="For Physicians & Clinics"
    subtitle="Full diagnostic ultrasound technologist services for your practice"
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'Partners' }]}
  />

  <!-- Value Proposition -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">Partner Services</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Reliable Diagnostic Ultrasound Staffing for Your Practice</h2>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            For over a decade, Signal View has provided full diagnostic ultrasound technologist services to clinics across the Las Vegas valley. Our credentialed sonographers integrate seamlessly into your practice — bringing hospital-grade expertise without the overhead of a full-time hire.
          </p>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            Whether you need regular weekly coverage, on-call support, or a dedicated sonographer for your growing practice, we have the experienced professionals to meet your needs.
          </p>
        </div>

        <div class="fade-in-up">
          <img
            src={serviceCarotid.src}
            alt="Sonographer performing diagnostic ultrasound in a clinical setting"
            class="rounded-2xl w-full aspect-[4/3] object-cover shadow-lg"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <p class="overline text-gold mb-3">Our Capabilities</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">What We Bring to Your Practice</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto fade-in-up">
        <div class="bg-white rounded-card p-6 shadow-md border border-warmgray/30">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Vascular & Cardiac</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">Full diagnostic echocardiograms, carotid duplex, arterial & venous studies, aorta, and peripheral vascular exams.</p>
        </div>

        <div class="bg-white rounded-card p-6 shadow-md border border-warmgray/30">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Credentialed Sonographers</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">ARDMS-registered professionals with 5+ years of hands-on diagnostic experience. Reliable, professional, and ready to work.</p>
        </div>

        <div class="bg-white rounded-card p-6 shadow-md border border-warmgray/30">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Flexible Scheduling</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">Regular weekly coverage, per-diem staffing, or on-call availability. We adapt to your patient volume and schedule.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Partner With Us -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <div class="text-center mb-10 fade-in-up">
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Why Clinics Choose Signal View</h2>
      </div>

      <div class="space-y-4 fade-in-up">
        {[
          { title: '10+ Years in Las Vegas', desc: 'We\'ve partnered with clinics across the valley for over a decade. We understand the local healthcare landscape and deliver consistently.' },
          { title: 'No Overhead, No Hassle', desc: 'Skip the cost of hiring, credentialing, and managing a full-time sonographer. We handle everything — you get expert-level imaging.' },
          { title: 'Hospital-Grade Equipment', desc: 'We bring our own state-of-the-art ultrasound equipment or seamlessly integrate with yours.' },
          { title: 'Seamless Integration', desc: 'Our sonographers work within your existing workflow — patient scheduling, reporting, and physician communication handled professionally.' },
        ].map((item) => (
          <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
            <h3 class="font-sans font-semibold text-charcoal mb-1">{item.title}</h3>
            <p class="text-sm text-slate font-sans leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Contact Form -->
  <section id="partner-inquiry" class="section-padding bg-navy">
    <div class="container-site max-w-2xl">
      <div class="text-center mb-10 fade-in-up">
        <p class="overline text-gold mb-3">Get In Touch</p>
        <h2 class="text-3xl md:text-4xl font-serif text-white">Partner With Us</h2>
        <p class="mt-3 text-lg text-white/70 font-sans">Tell us about your practice and staffing needs. We'll get back to you within one business day.</p>
      </div>

      <form id="partner-form" class="bg-white rounded-card shadow-lg p-6 md:p-8 space-y-5 fade-in-up">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="partner-name" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Your Name *</label>
            <input type="text" id="partner-name" name="name" required
              class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              placeholder="Dr. Jane Smith" />
          </div>
          <div>
            <label for="partner-phone" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Phone Number *</label>
            <input type="tel" id="partner-phone" name="phone" required
              class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              placeholder="(702) 555-0123" />
          </div>
        </div>

        <div>
          <label for="partner-email" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Email Address *</label>
          <input type="email" id="partner-email" name="email" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            placeholder="you@yourpractice.com" />
        </div>

        <div>
          <label for="partner-practice" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Practice / Clinic Name *</label>
          <input type="text" id="partner-practice" name="practice" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            placeholder="Your clinic or practice name" />
        </div>

        <div>
          <label for="partner-needs" class="block text-sm font-sans font-medium text-charcoal mb-1.5">What services are you looking for? *</label>
          <select id="partner-needs" name="needs" required
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
            <option value="">Select an option...</option>
            <option value="regular-staffing">Regular weekly sonographer staffing</option>
            <option value="per-diem">Per-diem / on-call coverage</option>
            <option value="full-service">Full diagnostic ultrasound service</option>
            <option value="equipment-tech">Equipment + technologist package</option>
            <option value="other">Other — describe below</option>
          </select>
        </div>

        <div>
          <label for="partner-message" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Tell us more about your needs</label>
          <textarea id="partner-message" name="message" rows="4"
            class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
            placeholder="Patient volume, scheduling preferences, types of exams needed, etc."></textarea>
        </div>

        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="w-full py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
          Submit Partnership Inquiry
        </button>

        <p class="text-center text-xs text-slate font-sans">
          We'll respond within one business day to discuss how we can support your practice.
        </p>
      </form>

      <p class="text-center mt-6 text-sm text-white/60 font-sans fade-in-up">
        Prefer to call?
        <a href={`tel:${siteConfig.phoneTel}`} class="text-gold font-medium hover:text-gold-light transition-colors">{siteConfig.phone}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('partner-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var honeypot = form.querySelector('input[name="website"]');
      if (honeypot && honeypot.value) return;

      var data = new FormData(form);
      var entries = {};
      data.forEach(function(value, key) { entries[key] = value; });

      var subject = encodeURIComponent('Partnership Inquiry: ' + entries.practice);
      var body = encodeURIComponent(
        'Name: ' + entries.name +
        '\nPhone: ' + entries.phone +
        '\nEmail: ' + entries.email +
        '\nPractice: ' + entries.practice +
        '\nServices Needed: ' + entries.needs +
        '\nMessage: ' + (entries.message || 'None')
      );
      window.location.href = 'mailto:signalviewultrasound@gmail.com?subject=' + subject + '&body=' + body;

      var btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.textContent = 'Opening Email — Thank You!';
        btn.classList.remove('bg-gold', 'hover:bg-gold-hover');
        btn.classList.add('bg-green-600');
        btn.disabled = true;
      }
    });
  });
</script>
