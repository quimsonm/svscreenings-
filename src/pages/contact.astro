---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="Contact Us | Signal View Screenings Las Vegas | 702.843.6612"
  description="Contact Signal View Screenings in Las Vegas. Call 702.843.6612, visit Frontline Medical Group on Saturdays 9am-1pm, or send us a message. Serving Las Vegas, Henderson, Summerlin."
>
  <PageHero
    title="Get in Touch"
    subtitle="Questions? We're here to help."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
  />

  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-2 fade-in-up">
          <h2 class="text-2xl font-serif text-charcoal mb-6">Contact Information</h2>

          <div class="space-y-5">
            <a href={`tel:${siteConfig.phoneTel}`} class="flex items-start gap-4 p-4 bg-ivory rounded-card border border-warmgray/40 hover:border-gold/40 transition-colors group">
              <div class="w-10 h-10 bg-gold/10 rounded-full flex items-center justify-center shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-sans font-semibold text-charcoal text-sm">Phone</p>
                <p class="text-sm text-slate font-sans">{siteConfig.phone}</p>
              </div>
            </a>

            <a href={`mailto:${siteConfig.email}`} class="flex items-start gap-4 p-4 bg-ivory rounded-card border border-warmgray/40 hover:border-gold/40 transition-colors group">
              <div class="w-10 h-10 bg-gold/10 rounded-full flex items-center justify-center shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-sans font-semibold text-charcoal text-sm">Email</p>
                <p class="text-sm text-slate font-sans">{siteConfig.email}</p>
              </div>
            </a>

            <div class="flex items-start gap-4 p-4 bg-ivory rounded-card border border-warmgray/40">
              <div class="w-10 h-10 bg-gold/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-sans font-semibold text-charcoal text-sm">Location</p>
                <p class="text-sm text-slate font-sans">{siteConfig.address.clinic}</p>
                <p class="text-sm text-slate font-sans">{siteConfig.address.full}</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-ivory rounded-card border border-warmgray/40">
              <div class="w-10 h-10 bg-gold/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-sans font-semibold text-charcoal text-sm">Hours</p>
                <p class="text-sm text-slate font-sans">{siteConfig.hours}</p>
                <p class="text-xs text-slate/70 font-sans mt-1">Gold Standard: Flexible scheduling available</p>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="mt-6 rounded-card overflow-hidden border border-warmgray/30">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3221.0!2d-115.284!3d36.197!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzbCsDExJzQ5LjIiTiAxMTXCsDE3JzAyLjQiVw!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Signal View Screenings Location"
            ></iframe>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3 fade-in-up">
          <h2 class="text-2xl font-serif text-charcoal mb-6">Send Us a Message</h2>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Quick booking CTA -->
  <section class="bg-navy py-12">
    <div class="container-site text-center">
      <p class="text-lg text-white/80 font-sans mb-4">Ready to book? Skip the form.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/pricing#booking" class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200">
          Book Your Screening
        </a>
        <a href={`tel:${siteConfig.phoneTel}`} class="text-white/70 hover:text-white font-sans text-sm transition-colors">
          or call {siteConfig.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
