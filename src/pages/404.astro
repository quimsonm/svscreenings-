---
import BaseLayout from '../layouts/BaseLayout.astro';
import { link } from '../utils/links';
---

<BaseLayout
  title="Page Not Found | Signal View Screenings"
  description="The page you're looking for doesn't exist."
>
  <section class="bg-navy relative overflow-hidden min-h-[60vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-dark/50 to-transparent"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>

    <div class="container-site relative text-center py-20">
      <p class="text-8xl font-serif text-gold/30 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-serif text-white mb-4">Page Not Found</h1>
      <p class="text-lg text-white/60 font-sans max-w-md mx-auto mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={link('/')} class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
          Go Home
        </a>
        <a href={link('/pricing')} class="inline-flex items-center px-8 py-3.5 border-2 border-white/30 hover:border-white/60 text-white font-sans font-medium rounded-lg transition-all duration-200">
          View Packages
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
