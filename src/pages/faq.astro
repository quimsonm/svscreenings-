---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import { faqs } from '../data/faq';
import { siteConfig } from '../data/siteConfig';

// Build FAQ schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<BaseLayout
  title="FAQ | Ultrasound Screening Questions | Signal View Screenings"
  description="Answers to common questions about ultrasound screenings: preparation, duration, results, pricing, insurance, and more. No referral needed."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <PageHero
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about our screening services"
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'FAQ' }]}
  />

  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <div class="fade-in-up">
        <FAQAccordion items={faqs} grouped={true} />
      </div>
    </div>
  </section>

  <!-- Still have questions -->
  <section class="section-padding bg-ivory">
    <div class="container-site text-center max-w-xl fade-in-up">
      <h2 class="text-3xl font-serif text-charcoal">Didn't Find Your Answer?</h2>
      <p class="mt-3 text-lg text-slate font-sans">We're happy to help with any questions about our screenings.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200">
          Contact Us
        </a>
        <a href={`tel:${siteConfig.phoneTel}`} class="inline-flex items-center gap-2 text-sm font-sans font-medium text-navy hover:text-gold transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {siteConfig.phone}
        </a>
      </div>
    </div>
  </section>

  <CTABanner heading="Ready to Book Your Screening?" subtext="Take the first step toward peace of mind." />
</BaseLayout>
