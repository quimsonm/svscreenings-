---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PricingCard from '../components/PricingCard.astro';
import { siteConfig } from '../data/siteConfig';
import CTABanner from '../components/CTABanner.astro';
import { packages } from '../data/packages';
import { services } from '../data/services';
import { link } from '../utils/links';

import conciergeHome from '../assets/images/concierge-home.png';
---

<BaseLayout
  title="Screening Packages & Pricing | From $199 | Signal View Screenings Las Vegas"
  description="Transparent pricing for ultrasound screening packages. Essential Wellness $199, Executive Heart $349, Gold Standard $597 with mobile white-glove service. No hidden fees."
>
  <PageHero
    title="Transparent, Simple Pricing"
    subtitle="No hidden fees. No referrals. No insurance headaches."
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'Pricing' }]}
  />

  <!-- Package Cards -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto fade-in-up">
        {packages.map((pkg) => (
          <PricingCard pkg={pkg} showDetails={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-4xl">
      <div class="text-center mb-10 fade-in-up">
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Package Comparison</h2>
        <p class="mt-3 text-lg text-slate font-sans">See exactly what's included in each package</p>
      </div>

      <div class="overflow-x-auto fade-in-up">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left py-4 px-4 text-sm font-sans font-semibold text-slate border-b-2 border-warmgray">Screening / Feature</th>
              {packages.map((pkg) => (
                <th class:list={[
                  'text-center py-4 px-4 text-sm font-sans font-semibold border-b-2',
                  pkg.highlighted ? 'text-gold border-gold' : 'text-charcoal border-warmgray',
                ]}>
                  {pkg.name}
                  <span class="block text-xs font-normal text-slate mt-0.5">${pkg.price}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {services.map((service) => (
              <tr class="border-b border-warmgray/50">
                <td class="py-3.5 px-4 text-sm font-sans text-charcoal">{service.shortTitle}</td>
                {packages.map((pkg) => (
                  <td class="py-3.5 px-4 text-center">
                    {service.includedIn.includes(pkg.name) ? (
                      <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                      </svg>
                    )}
                  </td>
                ))}
              </tr>
            ))}
            <!-- Extra features -->
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Mobile Service (We Come to You)</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                    </svg>
                  )}
                </td>
              ))}
            </tr>
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Physician-Signed Report</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                    </svg>
                  )}
                </td>
              ))}
            </tr>
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Flexible Scheduling</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <span class="text-xs text-slate font-sans">Saturdays</span>
                  )}
                </td>
              ))}
            </tr>
            <!-- Duration row -->
            <tr>
              <td class="py-3.5 px-4 text-sm font-sans font-semibold text-charcoal">Duration</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center text-sm font-sans text-charcoal">{pkg.duration}</td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Gold Standard Concierge Inquiry -->
  <section id="gold-standard-inquiry" class="section-padding bg-white">
    <div class="container-site max-w-5xl">
      <div id="booking" class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start fade-in-up">
        <!-- Left: Image + Benefits -->
        <div>
          <video
            id="gold-standard-video"
            muted
            playsinline
            preload="metadata"
            poster={conciergeHome.src}
            class="rounded-2xl w-full aspect-[4/3] object-cover shadow-lg mb-6"
          >
            <source src={link('/hero-video.mp4')} type="video/mp4" />
          </video>
          <ul class="space-y-3">
            {['All ultrasound screenings included', 'We come to your home or office', 'Flexible scheduling at your convenience', 'Physician-signed screening report'].map((item) => (
              <li class="flex items-center gap-2.5 text-sm font-sans text-charcoal">
                <svg class="w-4 h-4 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Inquiry Form -->
        <div>
          <p class="overline text-gold mb-3">The Gold Standard — $597</p>
          <h2 class="text-2xl md:text-3xl font-serif text-charcoal mb-2">Request Your Concierge Appointment</h2>
          <p class="text-slate font-sans text-sm mb-6">Tell us your preferred schedule and location. We'll call you within 24 hours to confirm.</p>

          <form id="gold-standard-form" class="bg-ivory rounded-card border border-warmgray/40 p-6 space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="gs-name" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Full Name *</label>
                <input type="text" id="gs-name" name="name" required
                  class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
                  placeholder="Your full name" />
              </div>
              <div>
                <label for="gs-phone" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Phone Number *</label>
                <input type="tel" id="gs-phone" name="phone" required
                  class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
                  placeholder="(702) 555-0123" />
              </div>
            </div>

            <div>
              <label for="gs-email" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Email Address *</label>
              <input type="email" id="gs-email" name="email" required
                class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
                placeholder="you@example.com" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="gs-dates" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Preferred Date(s) *</label>
                <input type="text" id="gs-dates" name="dates" required
                  class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
                  placeholder="e.g. Any Saturday in May" />
              </div>
              <div>
                <label for="gs-time" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Preferred Time</label>
                <select id="gs-time" name="time"
                  class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors bg-white">
                  <option value="flexible">Flexible</option>
                  <option value="morning">Morning</option>
                  <option value="afternoon">Afternoon</option>
                  <option value="evening">Evening</option>
                </select>
              </div>
            </div>

            <div>
              <label for="gs-location" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Screening Location *</label>
              <input type="text" id="gs-location" name="location" required
                class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
                placeholder="Home address or preferred location" />
            </div>

            <div>
              <label for="gs-notes" class="block text-sm font-sans font-medium text-charcoal mb-1.5">Special Notes</label>
              <textarea id="gs-notes" name="notes" rows="2"
                class="w-full px-4 py-3 border border-warmgray rounded-lg text-sm font-sans text-charcoal placeholder:text-slate/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
                placeholder="Any questions or special requests..."></textarea>
            </div>

            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <button type="submit" class="w-full py-3.5 bg-gold hover:bg-gold-hover text-white font-sans font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
              Request Your Appointment
            </button>

            <p class="text-center text-xs text-slate font-sans">
              We'll call you within 24 hours to confirm. Payment processed securely via Square after scheduling.
            </p>
          </form>

          <p class="text-center mt-4 text-sm text-slate font-sans">
            Prefer to call?
            <a href={`tel:${siteConfig.phoneTel}`} class="text-navy font-medium hover:text-gold transition-colors">{siteConfig.phone}</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Justification -->
  <section class="section-padding bg-ivory">
    <div class="container-site max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center fade-in-up">
        <div>
          <p class="overline text-gold mb-3">Worth Every Dollar</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Why These Screenings Are an Investment, Not an Expense</h2>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            The cost of a preventable emergency dwarfs the cost of early detection. Our screenings give you answers, peace of mind, and — most importantly — time.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-white rounded-card p-5 border border-warmgray/40">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-slate font-sans">ER visit for stroke</span>
              <span class="text-lg font-serif text-charcoal">$20,000+</span>
            </div>
          </div>
          <div class="bg-white rounded-card p-5 border border-warmgray/40">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-slate font-sans">Heart surgery</span>
              <span class="text-lg font-serif text-charcoal">$100,000+</span>
            </div>
          </div>
          <div class="bg-white rounded-card p-5 border border-gold shadow-md">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-gold-hover font-sans font-semibold">Signal View screening</span>
              <span class="text-lg font-serif text-gold">From $199</span>
            </div>
          </div>
          <p class="text-sm text-slate font-sans">
            <span class="font-medium text-charcoal">HSA/FSA eligible.</span> Preventative screenings are typically covered by health savings and flexible spending accounts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner heading="Questions About Our Packages?" subtext="Our team is happy to help you choose the right screening for your needs." ctaText="Contact Us" ctaHref={link('/contact')} />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // Auto-play video when arriving via anchor link
      var video = document.getElementById('gold-standard-video');
      if (video && (window.location.hash === '#gold-standard-inquiry' || window.location.hash === '#booking')) {
        video.play();
      }

      // Also play when section scrolls into view
      if (video) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              video.play();
              observer.disconnect();
            }
          });
        }, { threshold: 0.3 });
        observer.observe(video);
      }

      var form = document.getElementById('gold-standard-form');
      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var honeypot = form.querySelector('input[name="website"]');
        if (honeypot && honeypot.value) return;

        var data = new FormData(form);
        var entries = {};
        data.forEach(function(value, key) { entries[key] = value; });

        var subject = encodeURIComponent('Gold Standard Concierge Request');
        var body = encodeURIComponent(
          'Name: ' + entries.name +
          '\nPhone: ' + entries.phone +
          '\nEmail: ' + entries.email +
          '\nPreferred Date(s): ' + entries.dates +
          '\nPreferred Time: ' + entries.time +
          '\nLocation: ' + entries.location +
          '\nNotes: ' + (entries.notes || 'None')
        );
        window.location.href = 'mailto:signalviewultrasound@gmail.com?subject=' + subject + '&body=' + body;

        var btn = form.querySelector('button[type="submit"]');
        if (btn) {
          btn.textContent = 'Opening Email — Thank You!';
          btn.classList.remove('bg-gold', 'hover:bg-gold-hover');
          btn.classList.add('bg-green-600');
          btn.disabled = true;
        }
      });
    });
  </script>
</BaseLayout>
