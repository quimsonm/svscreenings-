---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PricingCard from '../components/PricingCard.astro';
import BookingForm from '../components/BookingForm.astro';
import CTABanner from '../components/CTABanner.astro';
import { packages } from '../data/packages';
import { services } from '../data/services';
import { link } from '../utils/links';

import conciergeHome from '../assets/images/concierge-home.png';
---

<BaseLayout
  title="Screening Packages & Pricing | From $199 | Signal View Screenings Las Vegas"
  description="Transparent pricing for ultrasound screening packages. Essential Wellness $199, Executive Heart $349, Gold Standard $597 with mobile white-glove service. No hidden fees."
>
  <PageHero
    title="Transparent, Simple Pricing"
    subtitle="No hidden fees. No referrals. No insurance headaches."
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'Pricing' }]}
  />

  <!-- Package Cards -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto fade-in-up">
        {packages.map((pkg) => (
          <PricingCard pkg={pkg} showDetails={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-4xl">
      <div class="text-center mb-10 fade-in-up">
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Package Comparison</h2>
        <p class="mt-3 text-lg text-slate font-sans">See exactly what's included in each package</p>
      </div>

      <div class="overflow-x-auto fade-in-up">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left py-4 px-4 text-sm font-sans font-semibold text-slate border-b-2 border-warmgray">Screening / Feature</th>
              {packages.map((pkg) => (
                <th class:list={[
                  'text-center py-4 px-4 text-sm font-sans font-semibold border-b-2',
                  pkg.highlighted ? 'text-gold border-gold' : 'text-charcoal border-warmgray',
                ]}>
                  {pkg.name}
                  <span class="block text-xs font-normal text-slate mt-0.5">${pkg.price}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {services.map((service) => (
              <tr class="border-b border-warmgray/50">
                <td class="py-3.5 px-4 text-sm font-sans text-charcoal">{service.shortTitle}</td>
                {packages.map((pkg) => (
                  <td class="py-3.5 px-4 text-center">
                    {pkg.features.some((f) => f.toLowerCase().includes(service.shortTitle.toLowerCase().split(' ')[0])) ? (
                      <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                      </svg>
                    )}
                  </td>
                ))}
              </tr>
            ))}
            <!-- Extra features -->
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Mobile Service (We Come to You)</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                    </svg>
                  )}
                </td>
              ))}
            </tr>
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Physician-Signed Report</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-warmgray mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                    </svg>
                  )}
                </td>
              ))}
            </tr>
            <tr class="border-b border-warmgray/50">
              <td class="py-3.5 px-4 text-sm font-sans text-charcoal">Flexible Scheduling</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center">
                  {pkg.slug === 'gold-standard' ? (
                    <svg class="w-5 h-5 text-gold mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <span class="text-xs text-slate font-sans">Saturdays</span>
                  )}
                </td>
              ))}
            </tr>
            <!-- Duration row -->
            <tr>
              <td class="py-3.5 px-4 text-sm font-sans font-semibold text-charcoal">Duration</td>
              {packages.map((pkg) => (
                <td class="py-3.5 px-4 text-center text-sm font-sans text-charcoal">{pkg.duration}</td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Gold Standard Concierge -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center fade-in-up">
        <div>
          <img
            src={conciergeHome.src}
            alt="Couple welcoming concierge screening service at their Las Vegas home"
            class="rounded-2xl w-full aspect-[4/3] object-cover shadow-lg"
            loading="lazy"
          />
        </div>
        <div>
          <p class="overline text-gold mb-3">The Gold Standard Experience</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">We Come to You</h2>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            Our premium concierge package brings hospital-grade ultrasound screenings directly to your home or office — anywhere in the Greater Las Vegas area. No clinic visits, no waiting rooms. Just expert care on your schedule.
          </p>
          <ul class="mt-6 space-y-3">
            {['All ultrasound screenings included', 'Flexible scheduling at your convenience', 'Physician-signed screening report', 'True white-glove experience'].map((item) => (
              <li class="flex items-center gap-2.5 text-sm font-sans text-charcoal">
                <svg class="w-4 h-4 text-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Justification -->
  <section class="section-padding bg-ivory">
    <div class="container-site max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center fade-in-up">
        <div>
          <p class="overline text-gold mb-3">Worth Every Dollar</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Why These Screenings Are an Investment, Not an Expense</h2>
          <p class="mt-4 text-slate font-sans leading-relaxed">
            The cost of a preventable emergency dwarfs the cost of early detection. Our screenings give you answers, peace of mind, and — most importantly — time.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-white rounded-card p-5 border border-warmgray/40">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-slate font-sans">ER visit for stroke</span>
              <span class="text-lg font-serif text-charcoal">$20,000+</span>
            </div>
          </div>
          <div class="bg-white rounded-card p-5 border border-warmgray/40">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-slate font-sans">Heart surgery</span>
              <span class="text-lg font-serif text-charcoal">$100,000+</span>
            </div>
          </div>
          <div class="bg-white rounded-card p-5 border border-gold shadow-md">
            <div class="flex items-baseline justify-between">
              <span class="text-sm text-gold-hover font-sans font-semibold">Signal View screening</span>
              <span class="text-lg font-serif text-gold">From $199</span>
            </div>
          </div>
          <p class="text-sm text-slate font-sans">
            <span class="font-medium text-charcoal">HSA/FSA eligible.</span> Preventative screenings are typically covered by health savings and flexible spending accounts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Form -->
  <BookingForm />

  <CTABanner heading="Questions About Our Packages?" subtext="Our team is happy to help you choose the right screening for your needs." ctaText="Contact Us" ctaHref={link('/contact')} />
</BaseLayout>
