---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';

const SQUARE_CAROTID_URL = 'https://book.squareup.com/appointments/1scmcc76vpn2fe/location/L0GR90314NDDP/services/POGYV6J3GYEXET4JTSGRNMON';

const trustPoints = [
  { icon: 'clock', text: '15 Minutes' },
  { icon: 'shield', text: 'No Referral Needed' },
  { icon: 'heart', text: 'No Needles or Radiation' },
  { icon: 'check', text: 'Results in 1 Business Day' },
];

const whyItMatters = [
  {
    stat: '80%',
    heading: 'of strokes are preventable',
    description: 'Most strokes are caused by a blockage that builds up silently over years. Early detection changes outcomes.',
  },
  {
    stat: '~50%',
    heading: 'of adults have carotid plaque',
    description: 'Plaque buildup in your carotid arteries is more common than most people realize — especially after age 50.',
  },
  {
    stat: '15 min',
    heading: 'is all it takes',
    description: 'A quick, painless ultrasound of your neck arteries can reveal what you can\'t feel — before it becomes an emergency.',
  },
];

const whoShouldGet = [
  'Over 50 years old',
  'Family history of stroke or heart disease',
  'High blood pressure or high cholesterol',
  'Diabetes or pre-diabetes',
  'Smoker or former smoker',
  'Simply want peace of mind',
];

const whatYouGet = [
  'One-on-one with an experienced sonographer — not an assembly line',
  'Real-time ultrasound of both left and right carotid arteries',
  'Plaque buildup and intimal thickening assessment',
  'Results reviewed by a board-certified radiologist',
  'Follow-up within 1 business day',
];
---

<BaseLayout
  title="$99 Carotid Screening | Know Your Stroke Risk | Signal View Screenings Las Vegas"
  description="A 15-minute carotid ultrasound that checks for plaque buildup in your neck arteries. $99 in Las Vegas. No referral needed. Book online or call 702.843.6612."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-dark/60 to-transparent"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gold/5 rounded-full -translate-y-1/3 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-gold/3 rounded-full translate-y-1/2 -translate-x-1/3"></div>

    <div class="container-site relative py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-gold/15 border border-gold/30 rounded-full px-4 py-1.5 mb-6 fade-in-up">
          <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
          <span class="text-sm font-sans font-medium text-gold">Limited Time Offer</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white leading-tight mb-4 fade-in-up">
          Know Your Stroke Risk
        </h1>
        <p class="text-xl md:text-2xl text-white/80 font-sans mb-2 fade-in-up">
          <span class="text-gold font-semibold">$99</span> Carotid Artery Screening
        </p>
        <p class="text-lg text-white/60 font-sans mb-8 max-w-2xl fade-in-up">
          A 15-minute ultrasound that checks for plaque buildup in your neck arteries — before it becomes an emergency.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10 fade-in-up">
          <a
            href={SQUARE_CAROTID_URL}
            target="_blank"
            rel="noopener noreferrer"
            onclick="window.svs_track && window.svs_track('begin_checkout', { package_name: 'Carotid Promo', value: 99, currency: 'USD' })"
            class="inline-flex items-center justify-center px-8 py-4 bg-gold hover:bg-gold-hover text-white font-sans font-semibold text-lg rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            Book Your $99 Screening →
          </a>
          <a
            href={`tel:${siteConfig.phoneTel}`}
            onclick="window.svs_track && window.svs_track('click_phone', { link_location: 'carotid_hero' })"
            class="inline-flex items-center justify-center gap-2 px-6 py-4 border-2 border-white/30 hover:border-white/60 text-white font-sans font-medium rounded-lg transition-all duration-200"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {siteConfig.phone}
          </a>
        </div>

        <!-- Trust strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 fade-in-up">
          {trustPoints.map((point) => (
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-full bg-gold/15 flex items-center justify-center shrink-0">
                {point.icon === 'clock' && (
                  <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
                  </svg>
                )}
                {point.icon === 'shield' && (
                  <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                )}
                {point.icon === 'heart' && (
                  <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
                  </svg>
                )}
                {point.icon === 'check' && (
                  <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                )}
              </div>
              <span class="text-sm text-white/70 font-sans">{point.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-12 fade-in-up">
        <p class="overline text-gold mb-3">Why It Matters</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Strokes Don't Warn You. This Screening Does.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {whyItMatters.map((item) => (
          <div class="text-center p-6 rounded-2xl border border-warmgray/30 bg-ivory/50 fade-in-up">
            <p class="text-5xl font-serif text-gold mb-2">{item.stat}</p>
            <p class="text-lg font-sans font-semibold text-charcoal mb-2">{item.heading}</p>
            <p class="text-sm text-slate font-sans leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What You'll Get -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">What's Included</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal mb-6">Your $99 Carotid Screening</h2>
          <ul class="space-y-4">
            {whatYouGet.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-base font-sans text-charcoal">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-2xl border border-warmgray/30 p-8 text-center fade-in-up">
          <p class="overline text-gold mb-2">Carotid Screening</p>
          <p class="text-6xl font-serif text-charcoal mb-1">$99</p>
          <p class="text-sm text-slate font-sans mb-6">One-time screening · No subscription</p>
          <a
            href={SQUARE_CAROTID_URL}
            target="_blank"
            rel="noopener noreferrer"
            onclick="window.svs_track && window.svs_track('begin_checkout', { package_name: 'Carotid Promo', value: 99, currency: 'USD' })"
            class="block w-full py-4 bg-gold hover:bg-gold-hover text-white font-sans font-semibold text-lg rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl mb-4"
          >
            Book Now →
          </a>
          <p class="text-xs text-slate font-sans">HSA/FSA eligible · Secure checkout via Square</p>
          <div class="mt-4 pt-4 border-t border-warmgray/20">
            <p class="text-xs text-slate font-sans">Or text us to book:</p>
            <a
              href={`sms:${siteConfig.phoneTel}`}
              onclick="window.svs_track && window.svs_track('click_text', { link_location: 'carotid_pricing_card' })"
              class="text-sm font-sans font-semibold text-navy hover:text-gold transition-colors"
            >
              {siteConfig.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Should Get Screened -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-4xl">
      <div class="text-center mb-10 fade-in-up">
        <p class="overline text-gold mb-3">Is This For You?</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">You Should Get Screened If...</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto fade-in-up">
        {whoShouldGet.map((item) => (
          <div class="flex items-center gap-3 p-4 rounded-xl bg-ivory border border-warmgray/20">
            <div class="w-8 h-8 rounded-full bg-gold/15 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-base font-sans text-charcoal">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Upgrade Section (soft upsell) -->
  <section class="section-padding bg-ivory">
    <div class="container-site max-w-4xl">
      <div class="text-center mb-10 fade-in-up">
        <p class="overline text-gold mb-3">While You're Here</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Want the Full Picture?</h2>
        <p class="mt-3 text-slate font-sans max-w-xl mx-auto">Most clients add the full vascular check while they're already in the clinic. Ask your sonographer about upgrading when you arrive.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto fade-in-up">
        <!-- Essential -->
        <div class="rounded-2xl border border-warmgray/30 bg-white p-6">
          <p class="text-sm font-sans font-medium text-slate mb-1">Essential Wellness</p>
          <p class="text-3xl font-serif text-charcoal mb-2">$199</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-2 text-sm font-sans text-slate">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Carotid + Aorta + Leg Arterial
            </li>
            <li class="flex items-start gap-2 text-sm font-sans text-slate">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              ~45 minute appointment
            </li>
          </ul>
          <a href={link('/pricing')} class="block w-full text-center py-2.5 rounded-lg font-sans font-semibold text-sm bg-navy hover:bg-navy/90 text-white transition-all duration-200">
            Learn More →
          </a>
        </div>

        <!-- Executive -->
        <div class="rounded-2xl border border-gold shadow-lg shadow-gold/10 ring-1 ring-gold/30 bg-white p-6">
          <div class="inline-block bg-gold text-white text-xs font-sans font-semibold tracking-wide px-3 py-1 rounded-full mb-2">Most Popular</div>
          <p class="text-sm font-sans font-medium text-slate mb-1">Executive Heart</p>
          <p class="text-3xl font-serif text-gold mb-2">$349</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-2 text-sm font-sans text-slate">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Everything in Essential + Echo
            </li>
            <li class="flex items-start gap-2 text-sm font-sans text-slate">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Most comprehensive in-clinic option
            </li>
          </ul>
          <a href={link('/pricing')} class="block w-full text-center py-2.5 rounded-lg font-sans font-semibold text-sm bg-gold hover:bg-gold-hover text-white transition-all duration-200">
            Learn More →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl text-center fade-in-up">
      <div class="flex items-center justify-center gap-1 mb-3">
        {[1,2,3,4,5].map(() => (
          <svg class="w-7 h-7 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <p class="text-lg font-sans text-charcoal mb-2">5-Star Rated on Google</p>
      <p class="text-slate font-sans text-sm mb-6">Real reviews from real patients in Las Vegas</p>
      <a
        href={siteConfig.googleReviewsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-sans font-medium text-navy hover:text-gold transition-colors"
      >
        Read Our Reviews →
      </a>
    </div>
  </section>

  <!-- Final CTA -->
  <CTABanner
    heading="$99 Carotid Screening — Book Yours Today"
    subtext="15 minutes. No referral. Just peace of mind about your stroke risk."
    ctaText="Book Your $99 Screening"
    ctaHref={SQUARE_CAROTID_URL}
  />

  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalTest",
    "name": "Carotid Artery Ultrasound Screening",
    "description": "A 15-minute carotid ultrasound screening that checks for plaque buildup and intimal thickening in the neck arteries to assess stroke risk.",
    "usesDevice": {
      "@type": "MedicalDevice",
      "name": "Ultrasound"
    },
    "offers": {
      "@type": "Offer",
      "price": "99",
      "priceCurrency": "USD",
      "url": SQUARE_CAROTID_URL
    },
    "provider": {
      "@type": "MedicalBusiness",
      "name": siteConfig.legalName,
      "telephone": siteConfig.phone,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": siteConfig.screeningLocation.address,
        "addressLocality": siteConfig.screeningLocation.city,
        "addressRegion": siteConfig.screeningLocation.state
      }
    }
  })} />
</BaseLayout>
