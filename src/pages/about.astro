---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
import { link } from '../utils/links';
---

<BaseLayout
  title="About Us | 10+ Years Diagnostic Experience | Signal View Screenings"
  description="Meet the certified sonographers behind Signal View Screenings. 10+ years of diagnostic ultrasound experience with Las Vegas clinics. Now bringing hospital-grade screenings directly to you."
>
  <PageHero
    title="About Signal View Screenings"
    subtitle="A decade of diagnostic experience. Now available directly to you."
    breadcrumbs={[{ label: 'Home', href: link('/') }, { label: 'About' }]}
  />

  <!-- Our Story -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">Our Story</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Our Mission</h2>
          <div class="mt-6 space-y-4 text-slate font-sans leading-relaxed">
            <p>
              For over a decade, Signal View has partnered with Las Vegas clinics performing full diagnostic ultrasounds — the same imaging technology used in hospitals to diagnose complex cardiovascular conditions.
            </p>
            <p>
              During those years, we saw a troubling pattern: patients arriving in emergency rooms with conditions that could have been caught years earlier with a simple, non-invasive screening. Strokes, aneurysms, arterial blockages — all detectable, all treatable, but only if you know to look.
            </p>
            <p>
              That's why we launched Signal View Screenings. We took our hospital-grade diagnostic expertise and made it directly accessible — no referrals, no long waits, no bureaucracy. Just answers.
            </p>
            <p>
              Whether you visit our clinic on a Saturday morning or choose our Gold Standard concierge service where we come to you, you'll receive the same expert-level care from our certified sonographers — because your health is worth more than a guessing game.
            </p>
          </div>
        </div>

        {/* To add a real image: import it at top, then replace placeholder below with:
            <img src={yourImage.src} alt="Signal View Screenings team" class="rounded-2xl w-full aspect-square object-cover shadow-lg" /> */}
        <div class="fade-in-up">
          <div class="relative rounded-2xl aspect-square overflow-hidden border border-warmgray/20 shadow-lg">
            <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy-dark to-navy"></div>
            <div class="absolute inset-0 bg-gradient-to-tr from-gold/10 via-transparent to-gold/5"></div>
            <div class="relative h-full flex flex-col items-center justify-center p-8">
              <div class="w-24 h-24 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-5">
                <svg class="w-12 h-12 text-gold/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
              </div>
              <p class="text-white/40 text-sm font-sans font-medium tracking-wide uppercase">Our Team</p>
              <div class="mt-4 w-16 h-px bg-gold/30"></div>
              <p class="mt-4 text-white/25 text-xs font-sans">10+ Years of Diagnostic Excellence</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team / Credentials -->
  <section class="section-padding bg-ivory">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <p class="overline text-gold mb-3">Our Team</p>
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Expert Sonographers You Can Trust</h2>
        <p class="mt-3 text-lg text-slate font-sans">Every screening is performed by a certified professional with years of diagnostic experience.</p>
      </div>

      <!-- Credentials Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto fade-in-up">
        <div class="bg-white rounded-card p-6 text-center shadow-md border border-warmgray/30">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Hospital-Grade Equipment</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">We use the same ultrasound technology found in top hospitals — delivering diagnostic-quality images in every screening.</p>
        </div>

        <div class="bg-white rounded-card p-6 text-center shadow-md border border-warmgray/30">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Certified Professionals</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">Our sonographers hold advanced certifications and have 5+ years of hands-on diagnostic ultrasound experience.</p>
        </div>

        <div class="bg-white rounded-card p-6 text-center shadow-md border border-warmgray/30">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-2">Results You Understand</h3>
          <p class="text-sm text-slate font-sans leading-relaxed">We explain your results in clear, everyday language — so you know exactly what your screening found and what it means.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="fade-in-up">
          <p class="overline text-gold mb-3">Our Location</p>
          <h2 class="text-3xl md:text-4xl font-serif text-charcoal">Serving the Greater Las Vegas Area</h2>
          <div class="mt-6 space-y-4">
            <div class="bg-ivory rounded-card p-5 border border-warmgray/40">
              <h3 class="font-sans font-semibold text-charcoal mb-1">{siteConfig.address.clinic}</h3>
              <p class="text-sm text-slate font-sans">{siteConfig.address.full}</p>
              <p class="text-sm text-slate font-sans mt-1">{siteConfig.hours}</p>
            </div>
            <div>
              <h3 class="font-sans font-semibold text-charcoal mb-3">Areas We Serve</h3>
              <div class="grid grid-cols-2 gap-2">
                {siteConfig.serviceAreas.map((area) => (
                  <div class="flex items-center gap-2 text-sm text-slate font-sans">
                    <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {area}
                  </div>
                ))}
              </div>
            </div>
            <div class="bg-gold/5 border border-gold/20 rounded-card p-4">
              <p class="text-sm font-sans text-charcoal">
                <span class="font-semibold text-gold">Gold Standard mobile service</span> — We bring hospital-grade equipment directly to your home or office anywhere in the Greater Las Vegas metro.
              </p>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="fade-in-up">
          <div class="rounded-2xl overflow-hidden shadow-lg border border-warmgray/30">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3221.0!2d-115.284!3d36.197!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzbCsDExJzQ5LjIiTiAxMTXCsDE3JzAyLjQiVw!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="400"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Signal View Screenings Location"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner heading="Join Our Patients" subtext="Experience the Signal View difference. Book your screening today." />
</BaseLayout>
